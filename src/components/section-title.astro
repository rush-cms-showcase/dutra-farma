---
interface Props {
	title: string
	highlight?: string
	subtitle?: string
	align?: 'left' | 'center'
}

const { title, highlight, subtitle, align = 'left' } = Astro.props
---

<div
	class:list={[
		'w-full flex flex-col mb-10',
		align === 'center' ? 'items-center text-center mx-auto' : 'items-start text-left',
	]}
>
	<h2
		class="text-3xl font-extrabold tracking-tight text-slate-900 sm:text-4xl"
	>
		{title}
		{
			highlight && (
				<span class="text-red-600 block sm:inline">{highlight}</span>
			)
		}
	</h2>
	{
		subtitle && (
			<p class="mt-4 text-lg text-slate-600 max-w-2xl">{subtitle}</p>
		)
	}
</div>
