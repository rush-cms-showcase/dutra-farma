---
interface Props {
	unit: {
		name: string
		coordinates: [number, number]
	}
}

const { unit } = Astro.props
---

<div
	class="w-full h-80 z-10 bg-slate-100 store-map"
	id="store-map"
	data-lat={unit.coordinates[0]}
	data-lng={unit.coordinates[1]}
	data-name={unit.name}
>
	<div
		class="w-full h-full flex items-center justify-center animate-pulse text-slate-400 text-sm font-medium"
	>
		Carregando mapa...
	</div>
</div>

<script>
	let isLeafletLoaded = false

	const loadLeafletDynamically = async () => {
		if (isLeafletLoaded) return window.L

		await import('leaflet/dist/leaflet.css')
		const leafletModule = await import('leaflet')
		window.L = leafletModule.default || leafletModule
		isLeafletLoaded = true

		return window.L
	}

	const initStoreMap = async (mapElement: HTMLElement) => {
		if (!mapElement || mapElement.dataset.initialized) return

		mapElement.dataset.initialized = 'true'

		const L = await loadLeafletDynamically()

		// Clear existing map instance if navigating via SPA View Transitions
		// @ts-ignore
		if (L.DomUtil.get('store-map') !== null) {
			// @ts-ignore
			L.DomUtil.get('store-map')._leaflet_id = null
		}

		const lat = parseFloat(mapElement.dataset.lat || '0')
		const lng = parseFloat(mapElement.dataset.lng || '0')

		const map = L.map('store-map', {
			attributionControl: false,
			scrollWheelZoom: false,
		}).setView([lat, lng], 15)

		L.tileLayer(
			'https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png',
			{
				attribution: '&copy; OpenStreetMap &copy; CARTO',
				subdomains: 'abcd',
				maxZoom: 19,
			},
		).addTo(map)

		const customIcon = L.divIcon({
			className: 'custom-div-icon',
			html: `
        <div style="background-color: #dc2626; width: 32px; height: 32px; border-radius: 50%; display: flex; align-items: center; justify-content: center; box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1); border: 2px solid white;">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24"><path fill="white" d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5a2.5 2.5 0 0 1 0-5 2.5 2.5 0 0 1 0 5z"/></svg>
        </div>
      `,
			iconSize: [32, 32],
			iconAnchor: [16, 32],
		})

		L.marker([lat, lng], { icon: customIcon }).addTo(map)

		const loadingIndicator = mapElement.querySelector(
			'.animate-pulse',
		) as HTMLElement
		if (loadingIndicator && loadingIndicator.style) {
			loadingIndicator.style.display = 'none'
		}
	}

	const setupObserver = () => {
		const mapElement = document.getElementById('store-map')
		if (!mapElement) return

		const observer = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						initStoreMap(mapElement)
						observer.disconnect()
					}
				})
			},
			{ rootMargin: '200px' },
		)

		observer.observe(mapElement)
	}

	setupObserver()
	document.addEventListener('astro:page-load', setupObserver)
</script>

<style is:global>
	#store-map {
		background: #f1f5f9;
		font-family: inherit;
	}
</style>
