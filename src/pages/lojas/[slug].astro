---
import Layout from '@/layouts/layout.astro'
import Header from '@/components/header.astro'
import Footer from '@/components/footer.astro'
import { units } from '@/data/units'
import IconArrowLeft from '~icons/ph/arrow-left-bold'
import IconWhatsapp from '~icons/mdi/whatsapp'
import IconPhone from '~icons/ph/phone-duotone'
import StoreDetails from '@/components/store-details.astro'
import StoreMap from '@/components/store-map.astro'

export function getStaticPaths() {
	return units.map((unit) => ({
		params: { slug: unit.id },
		props: { unit },
	}))
}

const { unit } = Astro.props
---

<Layout
	title={`${unit.name} | Dutra Farma`}
	description={`Farmácia ${unit.name} da Dutra Farma localizada em ${unit.city}. Endereço: ${unit.address}. Peça também pelo WhatsApp.`}
>
	<Header />

	<main class="grow bg-slate-100/50 pt-10 pb-24">
		<div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
			<a
				href="/lojas"
				class="inline-flex items-center gap-2 text-sm font-semibold text-slate-500 hover:text-slate-900 mb-8 transition-colors"
			>
				<IconArrowLeft class="w-4 h-4" />
				Voltar para todas as unidades
			</a>

			<article
				class="bg-white rounded-[2.5rem] pt-8 sm:pt-12 shadow-2xl shadow-slate-200/50 ring-1 ring-slate-200 relative overflow-hidden flex flex-col"
			>
				<div
					class="absolute -top-32 -right-32 w-96 h-96 bg-red-50 rounded-full blur-3xl opacity-50 pointer-events-none"
				>
				</div>

				<div class="relative z-10 px-8 sm:px-12 pb-12">
					<div
						class="absolute -top-32 -right-32 w-96 h-96 bg-red-50 rounded-full blur-3xl opacity-50 pointer-events-none"
					>
					</div>

					<div class="relative z-10">
						<div>
							<h1
								class="text-4xl sm:text-5xl font-extrabold tracking-tight text-slate-900 mb-2"
							>
								{unit.name}
							</h1>
							<p class="text-xl text-slate-500 font-medium mb-10">
								{unit.city}, {unit.state}
							</p>
						</div>

						<StoreDetails unit={unit} />
					</div>
				</div>

				<div class="w-full rounded-b-[2.5rem] mt-4 overflow-hidden">
					<StoreMap unit={unit} />
				</div>
			</article>
		</div>
	</main>

	<Footer />
</Layout>
