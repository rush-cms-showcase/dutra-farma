---
import Layout from '@/layouts/layout.astro'
import Header from '@/components/header.astro'
import Footer from '@/components/footer.astro'
import { units } from '@/data/units'
import IconMapPin from '~icons/ph/map-pin-duotone'
import IconPhone from '~icons/ph/phone-duotone'
import IconWhatsapp from '~icons/mdi/whatsapp'
---

<Layout
	title="Nossas Lojas | Dutra Farma - Farmácia no Litoral Norte"
	description="Encontre a unidade da Dutra Farma mais próxima de você em Caraguatatuba e São Sebastião. Confira nossos endereços, telefones e horário de funcionamento."
>
	<Header />

	<main class="grow bg-slate-50 pt-16 pb-24">
		<div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
			<div class="max-w-3xl mb-16">
				<h1
					class="text-4xl font-extrabold tracking-tight text-slate-900 sm:text-5xl"
				>
					Encontre a Dutra Farma <span class="text-red-600"
						>mais perto</span
					> de você
				</h1>
				<p class="mt-4 text-xl text-slate-600">
					São 4 unidades estrategicamente localizadas para atender
					você e sua família com excelência e rapidez em Caraguá e São
					Sebastião.
				</p>
			</div>

			<div class="grid grid-cols-1 md:grid-cols-2 gap-8">
				{
					units.map((unit) => (
						<div
							class="group flex flex-col bg-white rounded-3xl p-8 shadow-sm hover:shadow-xl ring-1 ring-slate-200 hover:ring-red-200 transition-all hover:-translate-y-1"
						>
							<h2 class="text-2xl font-bold text-slate-900 group-hover:text-red-600 transition-colors mb-2">
								{unit.name}
							</h2>
							<p class="text-slate-500 font-medium mb-6">
								{unit.city}, {unit.state}
							</p>

							<div class="space-y-4 mb-8 grow">
								<div class="flex items-start gap-3">
									<IconMapPin class="w-6 h-6 text-red-500 shrink-0 mt-0.5 group-hover:scale-110 transition-transform" />
									<span class="text-slate-700 leading-relaxed">
										{unit.address} - {unit.neighborhood}
									</span>
								</div>
								<div class="flex items-center gap-3">
									<IconPhone class="w-6 h-6 text-slate-400 shrink-0" />
									<span class="text-slate-700 font-medium">
										{unit.phone}
									</span>
								</div>
							</div>

							<div class="pt-6 border-t border-slate-100 flex items-center justify-between gap-4">
								<a href={`/lojas/${unit.id}`} class="text-sm font-semibold text-red-600 group-hover:text-red-700 transition-colors w-full">
									Ver detalhes da loja &rarr;
								</a>
								{
									unit.whatsapp && (
										<a
											href={`https://wa.me/${unit.whatsapp}`}
											target="_blank"
											rel="noopener noreferrer"
											class="shrink-0 p-2.5 bg-[#25D366] text-white rounded-2xl hover:bg-[#20bd5a] transition-all shadow-lg shadow-[#25D366]/20 hover:scale-[1.05]"
											title="Chamar no WhatsApp"
										>
											<IconWhatsapp class="w-5 h-5" />
										</a>
									)
								}
							</div>
						</div>
					))
				}
			</div>
		</div>
	</main>

	<Footer />
</Layout>
